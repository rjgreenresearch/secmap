# ==============================================================================
# SECMap .gitignore
# ==============================================================================
# Prevents committing cached SEC filings (~130MB), production output,
# primary-source research documents, and development artifacts.
# ==============================================================================

# ---- SEC EDGAR Cache ----
# Cached SEC responses (submissions JSON, filing HTML/text). These are
# large (130MB+), user-specific, and regenerated automatically on first run.
# Users populate their own cache by running SECMap with network access.
cache/

# --- SEC Financial Statement and Notes Data Sets
# Cached SEC Notes datasets from 2025 and 2026
# captured from https://www.sec.gov/data-research/sec-markets-data/financial-statement-notes-data-sets
# Keep this private; we don't redistribute SEC data.
data/

# ---- Production & Research Output ----
# Run output contains your research data — CSVs, reports, logs.
# Keep this private; results are reproducible from source.
output/

# ---- SEC Universe Data ----
# Downloaded from SEC on first run. 780KB-1.3MB each.
# Users fetch their own copy; we don't redistribute SEC data.
company_tickers.json
company_tickers_exchange.json
company_tickers_mf.json

# ---- Primary-Source Research Documents ----
# PDFs, ZIPs, and Excel files from Texas SOS, AFIDA, EDGAR downloads.
# These are your research inputs, not distributable code.
*.pdf
*.zip
*.xlsx
*.xls
*.csv
# Exception: installations_71.csv and any CSV that IS the deliverable
# should be force-added: git add -f installations_71.csv

# ---- Development Chat Logs ----
# Claude/Copilot session logs — useful for you, not for the repo.
q-dev-chat-*.md

# ---- Python Bytecode & Packaging ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
src/secmap.egg-info/
secmap.egg-info/

# ---- Testing Artifacts ----
.pytest_cache/
htmlcov/
.coverage
.coverage.*
test_reports/
*.html
# Exception: if you want to commit a test report, force-add it

# ---- Virtual Environments ----
.env
.envrc
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---- Type Checkers & Linters ----
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
cython_debug/

# ---- IDE / Editor ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ---- Cursor AI Editor ----
.cursorignore
.cursorindexingignore

# ---- PyPI Credentials ----
# NEVER commit package registry credentials
.pypirc

# ---- OS Generated ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Jupyter (if used for analysis) ----
.ipynb_checkpoints/
*.ipynb

# ---- Logs ----
*.log
logs/

# ---- Patent Drafts ----
# Keep private until filed. DO NOT commit.
# (Patent docs are in docs/ as .md which ARE committed —
#  this catches any Word/PDF working drafts at root level)
# DO NOT Uncomment these lines UNTIL the patent is filed:
# docs/SCEMap - Patent Claims.md
# docs/SCEMap - Patent-Ready Description.md
# docs/SCEMap - Patentability Analysis.md
# docs/SCEMap - Utility Patent Application Draft.md
